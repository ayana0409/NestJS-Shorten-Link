# Backend environment variables for shorter-link-backend
# Example MongoDB connection string: mongodb://localhost:27017/shorter-link
# or mongodb+srv://<user>:<password>@cluster.example.net/<dbname>?retryWrites=true&w=majority
MONGO_DB_CONNECTIONSTRING=xxx

PORT=3000
CORS_ORIGIN=http://localhost:3000

# Short URL generation settings
# NOTE: this value is treated as minutes, not days
SHORT_URL_LENGTH=6
SHORT_URL_EXPIRATION_DAYS=3

JWT_SECRET=your_jwt_secret_here
EXPIRES=1h

# Default admin seed account
ADMIN_USERNAME=admin
ADMIN_FULLNAME=xxx
ADMIN_PASSWORD=xxx
